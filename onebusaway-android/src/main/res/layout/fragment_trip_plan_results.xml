<!-- The option cards + list/map tabs and the directions list are Jetpack Compose
     (TripResultsHeader / TripResultsList). The map remains the native ObaMapFragment, hosted in
     the mapFragment frame and shown/hidden by the tab. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
              android:orientation="vertical"
              android:layout_width="match_parent"
              android:layout_height="match_parent">

    <androidx.compose.ui.platform.ComposeView
            android:id="@+id/results_header_compose"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

    <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dip"
            android:layout_weight="1"
            android:id="@+id/directionsFrame">

        <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:id="@+id/mapFragment"/>

        <androidx.compose.ui.platform.ComposeView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:id="@+id/results_list_compose"/>

    </FrameLayout>

</LinearLayout>
