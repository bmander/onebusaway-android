     The map itself is now composed directly by HomeScreen via ObaMap() — the old
     `main_fragment_container` mount point is gone. This layout survives only as the thin overlay shim
     for the two legacy View overlays still reached via findViewById (the survey card + the route-mode
     header); HomeScreen draws it via AndroidView above the map until those are Composed too.
-->
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
                android:id="@+id/main_content"
                android:layout_width="match_parent"
                android:layout_height="match_parent">

    <!-- The map, my-location/zoom/layers FABs, weather chip, donation card, and map-loading indicator
         are all Compose now (ObaMap + MapChrome / WeatherCard / DonationCard), so they no longer live
         here. Only the two not-yet-Composed overlays below remain. -->

    <include
        android:id="@+id/surveyView"
        android:layout_width="match_parent"
        android:layout_marginStart="8dp"
        android:visibility="gone"
        android:layout_marginEnd="8dp"
        android:layout_marginTop="58dp"
        android:layout_height="wrap_content"
        layout="@layout/item_survey"/>

    <!-- The route-mode header is now the Compose RouteHeaderOverlay (driven by MapViewModel.routeHeader),
         and the map-loading indicator is the Compose LinearProgressIndicator in MapChrome. -->
</RelativeLayout>
