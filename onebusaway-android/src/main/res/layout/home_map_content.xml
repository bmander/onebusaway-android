     P2 of the HomeActivity Compose migration: the former `main_content` subtree (the map container
     plus its overlaid chrome) extracted as a standalone root so it can be the `content` of a Compose
     BottomSheetScaffold. The arrivals panel that used to be the SlidingUpPanelLayout's second child
     now lives in home_arrivals_sheet.xml as the scaffold's `sheetContent`.
-->
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
                xmlns:app="http://schemas.android.com/apk/res-auto"
                xmlns:tools="http://schemas.android.com/tools"
                android:id="@+id/main_content"
                android:layout_width="match_parent"
                android:layout_height="match_parent">

    <!-- Fragment is added here programmatically -->
    <RelativeLayout
            android:id="@+id/main_fragment_container"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>
    <!-- The my-location FAB, zoom controls, and layers FAB are now the Compose MapChrome overlay
         (see HomeShellHost / MapChrome.kt), so they no longer live here. -->

    <!-- The weather chip is now the Compose WeatherCard overlay (see HomeShellHost / WeatherCard.kt). -->

    <include layout="@layout/donation_view" />
    <include
        android:id="@+id/surveyView"
        android:layout_width="match_parent"
        android:layout_marginStart="8dp"
        android:visibility="gone"
        android:layout_marginEnd="8dp"
        android:layout_marginTop="58dp"
        android:layout_height="wrap_content"
        layout="@layout/item_survey"/>

    <!-- ROUTE MODE HEADER -->
    <include android:id="@+id/route_info"
             layout="@layout/route_info_head"
             android:layout_width="fill_parent"
             android:layout_height="wrap_content"
             android:layout_alignParentTop="true"
             android:layout_alignParentLeft="true"
             android:visibility="gone"/>
    <ProgressBar
            android:id="@+id/progress_horizontal"
            style="@style/Base.Widget.AppCompat.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="-7dp"
            android:layout_below="@+id/route_info"
            android:indeterminate="true"/>
</RelativeLayout>
