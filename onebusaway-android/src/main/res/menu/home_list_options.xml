     The HomeActivity toolbar items for the in-place list destinations (starred stops/routes,
     reminders), replacing the per-fragment my_starred_*_options menus. Sort shows on all three list
     tabs; clear only on the two starred tabs (its label is set per-tab in HomeActivity).
-->
<menu xmlns:android="http://schemas.android.com/apk/res/android"
      xmlns:app="http://schemas.android.com/apk/res-auto">
    <group android:id="@+id/home_list_sort">
        <item android:id="@+id/home_list_sort_action"
              android:title="@string/menu_option_sort_by"
              android:icon="@drawable/ic_action_content_sort"
              app:showAsAction="ifRoom"
              app:iconTint="?attr/colorControlNormal"/>
    </group>
    <group android:id="@+id/home_list_clear">
        <item android:id="@+id/home_list_clear_action"
              android:title="@string/my_option_clear_starred_stops"
              android:icon="@android:drawable/ic_menu_close_clear_cancel"/>
    </group>
</menu>
