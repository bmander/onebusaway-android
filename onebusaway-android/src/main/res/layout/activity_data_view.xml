<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <include layout="@layout/include_toolbar" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Section 1: Polling Status -->
            <TextView
                style="@style/VehicleDebugSectionHeader"
                android:text="@string/data_views_section_polling" />

            <TextView
                android:id="@+id/polling_status"
                style="@style/VehicleDebugRow" />

            <!-- Section 2: Active Subscriptions -->
            <TextView
                style="@style/VehicleDebugSectionHeader"
                android:text="@string/data_views_section_subscriptions" />

            <TextView
                android:id="@+id/subscriptions_empty"
                style="@style/VehicleDebugRow"
                android:text="@string/data_views_no_subscriptions" />

            <LinearLayout
                android:id="@+id/subscriptions_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <!-- Section 3: Collected Trip Data -->
            <TextView
                style="@style/VehicleDebugSectionHeader"
                android:text="@string/data_views_section_collected" />

            <TextView
                android:id="@+id/collected_data_empty"
                style="@style/VehicleDebugRow"
                android:text="@string/data_views_empty" />

            <LinearLayout
                android:id="@+id/collected_data_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
